void cashierAddTrain() {
    printHeader("ДОДАТИ НОВИЙ ПОЇЗД");
    cin.ignore(numeric_limits<streamsize>::max(), '\n');

    Train t;
    t.id = gNextTrainId++;

    cout << "  Номер поїзда: ";
    getline(cin, t.number);

    cout << "  Тип поїзда: ";
    getline(cin, t.type);

    cout << "  Станція відправлення: ";
    getline(cin, t.stationFrom);

    cout << "  Кінцева станція: ";
    getline(cin, t.stationTo);

    cout << "  Час відправлення: ";
    getline(cin, t.departureTime);

    cout << "  Кількість проміжних зупинок: ";
    int ns; cin >> ns;
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
    for (int i = 0; i < ns; ++i) {
        cout << "    Зупинка " << i + 1 << ": ";
        string s; getline(cin, s);
        t.stops.push_back(s);
    }

    cout << "  Ціна Купе (грн): ";
    cin >> t.priceCoupe;
    cout << "  Ціна Плацкарт (грн): ";
    cin >> t.pricePlatz;

    gTrains.push_back(t);
    cout << "\n  ✓ Поїзд №" << t.number << " додано до системи.\n";
    pauseEnter();
}

void cashierListTrains() {
    printHeader("СПИСОК ПОЇЗДІВ У СИСТЕМІ");
    if (gTrains.empty()) {
        cout << "  Поїздів немає.\n";
    } else {
        for (const auto& t : gTrains) {
            printTrain(t);
            printLine('-', 60);
        }
    }
    pauseEnter();
}

void cashierDeleteTrain() {
    printHeader("ВИДАЛИТИ ПОЇЗД");
    if (gTrains.empty()) { cout << "  Поїздів немає.\n"; pauseEnter(); return; }
    for (size_t i = 0; i < gTrains.size(); ++i) {
        cout << "  [" << i + 1 << "] №" << gTrains[i].number
             << " — " << gTrains[i].stationFrom << " → " << gTrains[i].stationTo << "\n";
    }
    cout << "  Оберіть номер для видалення: ";
    int c; cin >> c;
    if (c >= 1 && c <= (int)gTrains.size()) {
        cout << "  Поїзд №" << gTrains[c - 1].number << " видалено.\n";
        gTrains.erase(gTrains.begin() + c - 1);
    }
    pauseEnter();
}

void cashierMenu() {
    while (true) {
        clearScreen();
        printHeader("МОДУЛЬ КАСИРА");
        cout << "  [1] Додати новий поїзд\n";
        cout << "  [2] Переглянути всі поїзди\n";
        cout << "  [3] Видалити поїзд\n";
        cout << "  [0] Назад\n";
        printLine();
        cout << "  Ваш вибір: ";
        int c; cin >> c;
        switch (c) {
            case 1: cashierAddTrain();   break;
            case 2: cashierListTrains(); break;
            case 3: cashierDeleteTrain(); break;
            case 0: return;
        }
    }
}

// ─────────────────────────────────────────────
//  РЕЄСТР ЗАЯВОК
// ─────────────────────────────────────────────

void viewRequests() {
    clearScreen();
    printHeader("РЕЄСТР ЗАЯВОК");
    if (gRequests.empty()) {
        cout << "  Заявок немає.\n";
        pauseEnter();
        return;
    }

    cout << left
         << setw(5)  << "№"
         << setw(20) << "Пасажир"
         << setw(24) << "Маршрут"
         << setw(12) << "Дата"
         << setw(8)  << "Поїзд"
         << setw(12) << "Сума"
         << "Статус\n";
    printLine('-', 90);

    for (const auto& r : gRequests) {
        string route = r.stationFrom + "→" + r.stationTo;
        if (route.size() > 22) route = route.substr(0, 20) + "..";

        string trainNum = "—";
        if (r.trainId != -1) {
            for (const auto& t : gTrains)
                if (t.id == r.trainId) { trainNum = t.number; break; }
            
            if (trainNum == "—") trainNum = "#" + to_string(r.trainId);
        }

        cout << left
             << setw(5)  << r.id
             << setw(20) << r.passengerName.substr(0, 18)
             << setw(24) << route
             << setw(12) << r.date
             << setw(8)  << trainNum
             << setw(12) << (r.totalPrice > 0 ? formatPrice(r.totalPrice) : "—")
             << statusToString(r.status) << "\n";
    }
    pauseEnter();
}

