#include <iostream>
#include <vector>
#include <string>
#include <iomanip>
#include <algorithm>
#include <sstream>
#include <limits>

using namespace std;

// ─────────────────────────────────────────────
//  Структури даних
// ─────────────────────────────────────────────

struct Train {
    int         id;
    string      number;       
    string      type;         
    string      stationFrom;
    string      stationTo;
    string      departureTime;
    vector<string> stops;     
    double      priceCoupe;
    double      pricePlatz;
};

enum class RequestStatus {
    Registered,
    Selected,
    Paid,
    Cancelled
};

string statusToString(RequestStatus s) {
    switch (s) {
        case RequestStatus::Registered: return "Зареєстровано";
        case RequestStatus::Selected:   return "Поїзд обрано";
        case RequestStatus::Paid:       return "Оплачено";
        case RequestStatus::Cancelled:  return "Скасовано";
    }
    return "";
}

struct Request {
    int           id;
    string        passengerName;
    string        passengerDoc;
    string        stationFrom;
    string        stationTo;
    string        date;
    string        time;
    RequestStatus status;
    int           trainId;    
    string        seatClass;  
    double        totalPrice;
};

// ─────────────────────────────────────────────
//  Глобальні дані
// ─────────────────────────────────────────────

vector<Train>   gTrains;
vector<Request> gRequests;
int             gNextTrainId   = 1;
int             gNextRequestId = 1;

// ─────────────────────────────────────────────
//  Утиліти виводу
// ─────────────────────────────────────────────

void clearScreen() {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}

void printLine(char c = '-', int n = 60) {
    cout << string(n, c) << "\n";
}

void printHeader(const string& title) {
    printLine('=');
    cout << "  " << title << "\n";
    printLine('=');
}

void pauseEnter() {
    cout << "\nНатисніть Enter для продовження...";
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
    cin.get();
}

string formatPrice(double p) {
    ostringstream ss;
    ss << fixed << setprecision(2) << p << " грн";
    return ss.str();
}

// ─────────────────────────────────────────────
//  Друк поїзда
// ─────────────────────────────────────────────

void printTrain(const Train& t, bool showIndex = false, int idx = 0) {
    if (showIndex) cout << "  [" << idx << "] ";
    else           cout << "  ";
    cout << "Поїзд №" << t.number
         << " (" << t.type << ")"
         << "  відпр. " << t.departureTime << "\n";
    cout << "      Маршрут: " << t.stationFrom << " → " << t.stationTo << "\n";
    if (!t.stops.empty()) {
        cout << "      Зупинки: ";
        for (size_t i = 0; i < t.stops.size(); ++i) {
            if (i) cout << ", ";
            cout << t.stops[i];
        }
        cout << "\n";
    }
    cout << "      Ціни:  Купе — " << formatPrice(t.priceCoupe)
         << "  |  Плацкарт — " << formatPrice(t.pricePlatz) << "\n";
}

