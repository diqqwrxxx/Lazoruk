// ─────────────────────────────────────────────
//  МОДУЛЬ ПАСАЖИРА
// ─────────────────────────────────────────────

void passengerMakeRequest() {
    printHeader("НОВА ЗАЯВКА ПАСАЖИРА");

    Request req;
    req.id      = gNextRequestId++;
    req.trainId = -1;
    req.totalPrice = 0;

    cout << "  Прізвище та ім'я пасажира: ";
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
    getline(cin, req.passengerName);

    cout << "  Номер документа: ";
    getline(cin, req.passengerDoc);

    cout << "  Станція відправлення: ";
    getline(cin, req.stationFrom);

    cout << "  Станція призначення:  ";
    getline(cin, req.stationTo);

    cout << "  Дата поїздки: ";
    getline(cin, req.date);

    cout << "  Бажаний час відправлення: ";
    getline(cin, req.time);

    req.status = RequestStatus::Registered;
    gRequests.push_back(req);

    cout << "\n  ✓ Заявку зареєстровано! Номер заявки: " << req.id << "\n";

    // Пошук поїздів
    vector<Train*> found;
    for (auto& t : gTrains) {
        if (t.stationFrom == req.stationFrom && t.stationTo == req.stationTo)
            found.push_back(&t);
    }

    if (found.empty()) {
        cout << "\n  На маршрут «" << req.stationFrom << " → " << req.stationTo
             << "» поїздів не знайдено.\n";
        pauseEnter();
        return;
    }

    cout << "\n  Знайдено поїздів: " << found.size() << "\n";
    printLine();
    for (size_t i = 0; i < found.size(); ++i)
        printTrain(*found[i], true, (int)i + 1);
    printLine();

    cout << "  Оберіть поїзд (1-" << found.size() << "): ";
    int choice;
    cin >> choice;
    if (choice < 1 || choice > (int)found.size()) {
        cout << "  Вибір скасовано.\n";
        pauseEnter();
        return;
    }

    Train* chosen = found[choice - 1];

    cout << "  Клас вагона:\n";
    cout << "    [1] Купе    — " << formatPrice(chosen->priceCoupe) << "\n";
    cout << "    [2] Плацкарт — " << formatPrice(chosen->pricePlatz) << "\n";
    cout << "  Ваш вибір: ";
    int cls;
    cin >> cls;
    if (cls != 1 && cls != 2) {
        cout << "  Невірний вибір.\n";
        pauseEnter();
        return;
    }

    // Оновлюємо заявку
    for (auto& r : gRequests) {
        if (r.id == req.id) {
            r.trainId    = chosen->id;
            r.seatClass  = (cls == 1) ? "Купе" : "Плацкарт";
            r.totalPrice = (cls == 1) ? chosen->priceCoupe : chosen->pricePlatz;
            r.status     = RequestStatus::Selected;

            // Рахунок
            double fee = r.totalPrice * 0.05;
            double total = r.totalPrice + fee;
            r.totalPrice = total;

            printLine('=');
            cout << "  РАХУНОК НА ОПЛАТУ\n";
            printLine('=');
            cout << "  Пасажир:    " << r.passengerName << "\n";
            cout << "  Документ:   " << r.passengerDoc  << "\n";
            cout << "  Маршрут:    " << r.stationFrom << " → " << r.stationTo << "\n";
            cout << "  Поїзд:      №" << chosen->number << " (" << chosen->type << ")\n";
            cout << "  Відправл.:  " << chosen->departureTime << "  Дата: " << r.date << "\n";
            cout << "  Клас:       " << r.seatClass << "\n";
            printLine();
            cout << "  Вартість проїзду:  " << formatPrice(r.totalPrice - fee) << "\n";
            cout << "  Сервісний збір 5%: " << formatPrice(fee) << "\n";
            printLine();
            cout << "  РАЗОМ ДО ОПЛАТИ:   " << formatPrice(total) << "\n";
            printLine('=');

            cout << "  Підтвердити оплату? [1/0]: ";
            int pay; cin >> pay;
            if (pay == 1) {
                r.status = RequestStatus::Paid;
                cout << "\n  ✓ Оплату прийнято! Квиток оформлено.\n";
                cout << "    Заявка №" << r.id << " · Поїзд " << chosen->number
                     << " · " << formatPrice(total) << "\n";
            } else {
                cout << "  Оплату скасовано. Заявка залишається зі статусом «Поїзд обрано».\n";
            }
            break;
        }
    }
    pauseEnter();
}

void passengerMenu() {
    while (true) {
        clearScreen();
        printHeader("МОДУЛЬ ПАСАЖИРА");
        cout << "  [1] Зробити заявку на квиток\n";
        cout << "  [0] Назад\n";
        printLine();
        cout << "  Ваш вибір: ";
        int c; cin >> c;
        if (c == 0) return;
        if (c == 1) passengerMakeRequest();
    }
}

