#include <iostream>
#include <cstring>

// ============================================================
//  Клас Tail (Хвіст)
// ============================================================
class Tail {
private:
    double length;   // довжина хвоста (см)

public:
    // Конструктор за замовчуванням
    Tail() : length(0.0) {
        std::cout << "[Tail] Конструктор за замовчуванням (length=0)\n";
    }

    // Конструктор з параметром
    explicit Tail(double len) : length(len) {
        std::cout << "[Tail] Конструктор з параметром (length=" << length << ")\n";
    }

    // Конструктор копіювання
    Tail(const Tail& other) : length(other.length) {
        std::cout << "[Tail] Конструктор копіювання (length=" << length << ")\n";
    }

    // Метод доступу: отримати довжину
    double getLength() const { return length; }

    // Метод доступу: встановити довжину
    void setLength(double len) { length = len; }

    ~Tail() {
        std::cout << "[Tail] Деструктор (length=" << length << ")\n";
    }
};

// ============================================================
//  Базовий клас Dog (Собака)
// ============================================================
class Dog {
private:
    Tail   tail;     // агрегований об'єкт «хвіст»
    char*  color;    // вказівник на рядок (колір шерсті)
    int    age;      // вік (роки)

public:
    // Конструктор за замовчуванням
    Dog() : tail(), age(0) {
        color = new char[1];
        color[0] = '\0';
        std::cout << "[Dog] Конструктор за замовчуванням\n";
    }

    // Конструктор з параметрами
    Dog(const char* clr, int a, double tailLen)
        : tail(tailLen), age(a)
    {
        color = new char[std::strlen(clr) + 1];
        std::strcpy(color, clr);
        std::cout << "[Dog] Конструктор з параметрами: color=\""
                  << color << "\", age=" << age << "\n";
    }

    // Конструктор копіювання (глибоке копіювання)
    Dog(const Dog& other) : tail(other.tail), age(other.age) {
        color = new char[std::strlen(other.color) + 1];
        std::strcpy(color, other.color);
        std::cout << "[Dog] Конструктор копіювання\n";
    }

    // Оператор присвоєння (глибоке копіювання)
    Dog& operator=(const Dog& other) {
        if (this == &other) return *this;
        delete[] color;
        color = new char[std::strlen(other.color) + 1];
        std::strcpy(color, other.color);
        age  = other.age;
        tail = other.tail;
        return *this;
    }

    // Методи доступу
    const char* getColor()  const { return color; }
    int         getAge()    const { return age; }
    double      getTailLen()const { return tail.getLength(); }

    void setColor(const char* clr) {
        delete[] color;
        color = new char[std::strlen(clr) + 1];
        std::strcpy(color, clr);
    }
    void setAge(int a)          { age = a; }
    void setTailLen(double len) { tail.setLength(len); }

    // Деструктор
    virtual ~Dog() {
        std::cout << "[Dog] Деструктор: color=\"" << color << "\"\n";
        delete[] color;
    }
};

// ============================================================
//  Похідний клас NamedDog (Собака з кличкою)
// ============================================================
class NamedDog : public Dog {
private:
    char* name;   // вказівник на рядок (кличка)

public:
    // Конструктор за замовчуванням
    NamedDog() : Dog() {
        name = new char[1];
        name[0] = '\0';
        std::cout << "[NamedDog] Конструктор за замовчуванням\n";
    }

    // Конструктор з параметрами
    NamedDog(const char* nm, const char* clr, int a, double tailLen)
        : Dog(clr, a, tailLen)
    {
        name = new char[std::strlen(nm) + 1];
        std::strcpy(name, nm);
        std::cout << "[NamedDog] Конструктор з параметрами: name=\""
                  << name << "\"\n";
    }

    // Конструктор копіювання
    NamedDog(const NamedDog& other) : Dog(other) {
        name = new char[std::strlen(other.name) + 1];
        std::strcpy(name, other.name);
        std::cout << "[NamedDog] Конструктор копіювання\n";
    }

    // Оператор присвоєння
    NamedDog& operator=(const NamedDog& other) {
        if (this == &other) return *this;
        Dog::operator=(other);
        delete[] name;
        name = new char[std::strlen(other.name) + 1];
        std::strcpy(name, other.name);
        return *this;
    }

    // Метод доступу
    const char* getName() const { return name; }
    void setName(const char* nm) {
        delete[] name;
        name = new char[std::strlen(nm) + 1];
        std::strcpy(name, nm);
    }

    // Функція друку
    void print() const {
        std::cout << "-------------------------------\n"
                  << "Кличка  : " << name          << "\n"
                  << "Колір   : " << getColor()    << "\n"
                  << "Вік     : " << getAge()      << " р.\n"
                  << "Хвіст   : " << getTailLen()  << " см\n"
                  << "-------------------------------\n";
    }

    // Деструктор
    ~NamedDog() override {
        std::cout << "[NamedDog] Деструктор: name=\"" << name << "\"\n";
        delete[] name;
    }
};

// ============================================================
//  main — демонстрація роботи
// ============================================================
int main() {
    std::cout << "=== Створення об'єктів ===\n";
    NamedDog dog1("Рекс",  "руда",   3, 25.0);
    NamedDog dog2("Кулька","чорна",  5, 18.5);
    NamedDog dog3;                         // конструктор за замовчуванням

    std::cout << "\n=== Друк dog1 ===\n";
    dog1.print();

    std::cout << "\n=== Друк dog2 ===\n";
    dog2.print();

    std::cout << "\n=== Копіювання dog1 -> dog3 ===\n";
    dog3 = dog1;
    dog3.setName("Рекс-молодший");
    dog3.print();

    std::cout << "\n=== Конструктор копіювання dog4(dog2) ===\n";
    NamedDog dog4(dog2);
    dog4.print();

    std::cout << "\n=== Знищення об'єктів ===\n";
    // деструктори викликаються автоматично при виході з блоку
    return 0;
}
