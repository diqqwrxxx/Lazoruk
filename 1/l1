#include <iostream>
#include <string>
#include <sstream>

using namespace std;

// ============================================================
//  Базовий клас Education (Освіта)
// ============================================================
class Education {
protected:
    string institution;   // назва закладу
    string specialty;     // спеціальність
    int    graduationYear;// рік закінчення

public:
    // ---- Конструктори ----------------------------------------
    Education()
        : institution(""), specialty(""), graduationYear(0)
    {
        cout << "[Education] Конструктор за замовчуванням\n";
    }

    Education(const string& inst,
              const string& spec,
              int year)
        : institution(inst), specialty(spec), graduationYear(year)
    {
        cout << "[Education] Конструктор з параметрами\n";
    }

    // Конструктор копіювання
    Education(const Education& other)
        : institution(other.institution),
          specialty(other.specialty),
          graduationYear(other.graduationYear)
    {
        cout << "[Education] Конструктор копіювання\n";
    }

    // ---- Оператор присвоювання ------------------------------
    Education& operator=(const Education& other) {
        if (this == &other) return *this;
        institution    = other.institution;
        specialty      = other.specialty;
        graduationYear = other.graduationYear;
        cout << "[Education] operator=\n";
        return *this;
    }

    // ---- Методи доступу ------------------------------------
    string getInstitution()   const { return institution; }
    string getSpecialty()     const { return specialty; }
    int    getGraduationYear()const { return graduationYear; }

    void setInstitution   (const string& v) { institution    = v; }
    void setSpecialty     (const string& v) { specialty      = v; }
    void setGraduationYear(int v)           { graduationYear = v; }

    // ---- Виведення / введення (virtual) --------------------
    virtual void print(ostream& os) const {
        os << "Заклад        : " << institution    << "\n"
           << "Спеціальність : " << specialty      << "\n"
           << "Рік закінчення: " << graduationYear << "\n";
    }

    virtual void read(istream& is) {
        cout << "  Заклад: ";
        getline(is >> ws, institution);
        cout << "  Спеціальність: ";
        getline(is >> ws, specialty);
        cout << "  Рік закінчення: ";
        is >> graduationYear;
    }

    // ---- Деструктор ----------------------------------------
    virtual ~Education() {
        cout << "[Education] Деструктор: " << institution << "\n";
    }
};

// Перевантаження << та >> для Education
ostream& operator<<(ostream& os, const Education& e) {
    e.print(os);
    return os;
}

istream& operator>>(istream& is, Education& e) {
    e.read(is);
    return is;
}

// ============================================================
//  Похідний клас HigherEducation (Вища освіта)
// ============================================================
class HigherEducation : public Education {
private:
    string degree;       // ступінь: бакалавр / магістр / PhD
    string department;   // кафедра / факультет
    double gpa;          // середній бал (GPA)

public:
    // ---- Конструктори ----------------------------------------
    HigherEducation()
        : Education(), degree(""), department(""), gpa(0.0)
    {
        cout << "[HigherEducation] Конструктор за замовчуванням\n";
    }

    HigherEducation(const string& inst,
                    const string& spec,
                    int           year,
                    const string& deg,
                    const string& dept,
                    double        gpaVal)
        : Education(inst, spec, year),
          degree(deg), department(dept), gpa(gpaVal)
    {
        cout << "[HigherEducation] Конструктор з параметрами\n";
    }

    // Конструктор копіювання через базовий клас
    HigherEducation(const HigherEducation& other)
        : Education(other),          // виклик конструктора копіювання базового
          degree(other.degree),
          department(other.department),
          gpa(other.gpa)
    {
        cout << "[HigherEducation] Конструктор копіювання\n";
    }

    // ---- Оператор присвоювання через базовий клас ----------
    HigherEducation& operator=(const HigherEducation& other) {
        if (this == &other) return *this;
        Education::operator=(other);   // присвоювання базової частини
        degree     = other.degree;
        department = other.department;
        gpa        = other.gpa;
        cout << "[HigherEducation] operator=\n";
        return *this;
    }

    // ---- Методи доступу ------------------------------------
    string getDegree()    const { return degree; }
    string getDepartment()const { return department; }
    double getGPA()       const { return gpa; }

    void setDegree    (const string& v) { degree     = v; }
    void setDepartment(const string& v) { department = v; }
    void setGPA       (double v)        { gpa        = v; }

    // ---- Перевизначення виведення --------------------------
    void print(ostream& os) const override {
        Education::print(os);                  // виводимо базову частину
        os << "Ступінь       : " << degree     << "\n"
           << "Кафедра       : " << department << "\n"
           << "Середній бал  : " << gpa        << "\n";
    }

    // ---- Перевизначення введення ---------------------------
    void read(istream& is) override {
        Education::read(is);                   // зчитуємо базову частину
        cout << "  Ступінь (бакалавр/магістр/PhD): ";
        getline(is >> ws, degree);
        cout << "  Кафедра/Факультет: ";
        getline(is >> ws, department);
        cout << "  Середній бал (GPA): ";
        is >> gpa;
    }

    // ---- Деструктор ----------------------------------------
    ~HigherEducation() override {
        cout << "[HigherEducation] Деструктор: " << degree << "\n";
    }
};

// ============================================================
//  main — демонстрація
// ============================================================
int main() {
    cout << "=== 1. Створення об'єктів ===\n";
    Education e1("Школа №5 м.Чернівці", "Загальна середня освіта", 2018);
    HigherEducation h1("ЧНУ ім. Федьковича", "Комп'ютерні науки", 2022,
                       "Бакалавр", "Кафедра комп'ютерних наук", 4.7);

    cout << "\n=== 2. Виведення (operator<<) ===\n";
    cout << "-- Education --\n"      << e1;
    cout << "-- HigherEducation --\n" << h1;

    cout << "\n=== 3. Конструктор копіювання HigherEducation ===\n";
    HigherEducation h2(h1);
    cout << "-- Копія h2 --\n" << h2;

    cout << "\n=== 4. Оператор присвоювання ===\n";
    HigherEducation h3;
    h3 = h1;
    h3.setDegree("Магістр");
    h3.setGPA(4.9);
    cout << "-- h3 після присвоювання і зміни --\n" << h3;

    cout << "\n=== 5. Поліморфне виведення через базовий вказівник ===\n";
    Education* ptr = &h1;
    cout << *ptr;   // викликає HigherEducation::print завдяки virtual

    cout << "\n=== 6. Введення з рядкового потоку (симуляція cin) ===\n";
    string input =
        "Технічний коледж\n"
        "Програмування\n"
        "2020\n"
        "Молодший спеціаліст\n"
        "ВК Інформатики\n"
        "4.2\n";
    istringstream iss(input);
    HigherEducation h4;
    h4.read(iss);
    cout << "-- Введений об'єкт h4 --\n" << h4;

    cout << "\n=== Знищення об'єктів ===\n";
    return 0;
}
