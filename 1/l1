#include <iostream>
#include <string>
#include <locale>

using namespace std;

class Tvaryna {
private:
    string klasyfikacija;
    int kintcivky;
    int naschadvky;

public:
    Tvaryna() {
        klasyfikacija = "Невідома";
        kintcivky = 0;
        naschadvky = 0;
    }

    Tvaryna(string klasif, int kintc, int naschad) {
        klasyfikacija = klasif;
        kintcivky = kintc;
        naschadvky = naschad;
    }

    virtual ~Tvaryna() {}

    virtual void druk() const {
        cout << "--- Інформація про тварину ---" << endl;
        cout << "Класифікація: " << klasyfikacija << endl;
        cout << "Число кінцівок: " << kintcivky << endl;
        cout << "Число нащадків: " << naschadvky << endl;
    }

    void zminyty_naschadvky(int nove_chyslo) {
        naschadvky = nove_chyslo;
    }

    int get_naschadvky() const {
        return naschadvky;
    }

    string get_klasyfikacija() const {
        return klasyfikacija;
    }

    int get_kintcivky() const {
        return kintcivky;
    }
};

class DomashnyaTvaryna : public Tvaryna {
private:
    string klychka;

public:
    DomashnyaTvaryna() : Tvaryna() {
        klychka = "Без клички";
    }

    DomashnyaTvaryna(string kych) : Tvaryna() {
        klychka = kych;
    }

    DomashnyaTvaryna(string kych, string klasif) : Tvaryna(klasif, 0, 0) {
        klychka = kych;
    }

    DomashnyaTvaryna(string kych, string klasif, int kintc) : Tvaryna(klasif, kintc, 0) {
        klychka = kych;
    }

    DomashnyaTvaryna(string kych, string klasif, int kintc, int naschad)
        : Tvaryna(klasif, kintc, naschad) {
        klychka = kych;
    }

    DomashnyaTvaryna(const DomashnyaTvaryna& other)
        : Tvaryna(other.get_klasyfikacija(), other.get_kintcivky(), other.get_naschadvky()) {
        klychka = other.klychka;
    }

    ~DomashnyaTvaryna() {}

    void druk() const override {
        cout << "\n=== Інформація про домашню тварину ===" << endl;
        Tvaryna::druk();
        cout << "Кличка: " << klychka << endl;
    }

    void zminyty_klychku(string nova_klychka) {
        klychka = nova_klychka;
    }

    void zminyty_naschadvky(int nove_chyslo) {
        Tvaryna::zminyty_naschadvky(nove_chyslo);
    }

    string get_klychka() const {
        return klychka;
    }
};

void testuvannya() {
    Tvaryna tv1;
    tv1.druk();

    Tvaryna tv2("Ссавець", 4, 5);
    tv2.druk();
    tv2.zminyty_naschadvky(10);

    DomashnyaTvaryna dt1;
    dt1.druk();

    DomashnyaTvaryna dt2("Барс");
    dt2.druk();

    DomashnyaTvaryna dt3("Мурзик", "Кіт");
    dt3.druk();

    DomashnyaTvaryna dt4("Рекс", "Собака", 4);
    dt4.druk();

    DomashnyaTvaryna dt5("Вовчиця", "Вовк", 4, 3);
    dt5.druk();

    DomashnyaTvaryna dt6 = dt5;
    dt6.druk();

    dt5.zminyty_klychku("Царівна");
    dt5.zminyty_naschadvky(7);
    dt5.druk();

    Tvaryna* ptv = &dt4;
    ptv->druk();

    cout << dt5.get_klychka() << endl;
    cout << dt4.get_klasyfikacija() << endl;
    cout << dt4.get_kintcivky() << endl;
    cout << dt5.get_naschadvky() << endl;
}

int main() {
    setlocale(LC_ALL, "");
    testuvannya();
    return 0;
}
