#include <iostream>
#include <cmath>
#include <string>

using namespace std;

class Quadrilateral {
public:
    virtual double area()      const = 0;
    virtual double perimeter() const = 0;
    virtual string name()      const = 0;

    virtual void print(ostream& os) const {
        os << "[ " << name() << " ]\n"
           << "  Площа    : " << area()      << "\n"
           << "  Периметр : " << perimeter() << "\n";
    }

    virtual ~Quadrilateral() = default;
};

ostream& operator<<(ostream& os, const Quadrilateral& q) {
    q.print(os);
    return os;
}

class Square : public Quadrilateral {
    double a;
public:
    Square(double side) : a(side) {}

    double area()      const override { return a * a; }
    double perimeter() const override { return 4 * a; }
    string name()      const override { return "Квадрат"; }

    void print(ostream& os) const override {
        os << "[ " << name() << " ]  a=" << a << "\n"
           << "  Площа    : " << area()      << "\n"
           << "  Периметр : " << perimeter() << "\n";
    }
};

class Rectangle : public Quadrilateral {
    double a, b;
public:
    Rectangle(double length, double width) : a(length), b(width) {}

    double area()      const override { return a * b; }
    double perimeter() const override { return 2 * (a + b); }
    string name()      const override { return "Прямокутник"; }

    void print(ostream& os) const override {
        os << "[ " << name() << " ]  a=" << a << "  b=" << b << "\n"
           << "  Площа    : " << area()      << "\n"
           << "  Периметр : " << perimeter() << "\n";
    }
};

class Parallelogram : public Quadrilateral {
    double a, b, alpha;
public:
    Parallelogram(double base, double side, double angleDeg)
        : a(base), b(side), alpha(angleDeg) {}

    double area()      const override { return a * b * sin(alpha * M_PI / 180.0); }
    double perimeter() const override { return 2 * (a + b); }
    string name()      const override { return "Паралелограм"; }

    void print(ostream& os) const override {
        os << "[ " << name() << " ]  a=" << a << "  b=" << b << "  alpha=" << alpha << "\n"
           << "  Площа    : " << area()      << "\n"
           << "  Периметр : " << perimeter() << "\n";
    }
};

class Trapezoid : public Quadrilateral {
    double a, b, c, d, h;
public:
    Trapezoid(double topBase, double botBase,
              double left, double right, double height)
        : a(topBase), b(botBase), c(left), d(right), h(height) {}

    double area()      const override { return (a + b) / 2.0 * h; }
    double perimeter() const override { return a + b + c + d; }
    string name()      const override { return "Трапеція"; }

    void print(ostream& os) const override {
        os << "[ " << name() << " ]  a=" << a << "  b=" << b
           << "  c=" << c << "  d=" << d << "  h=" << h << "\n"
           << "  Площа    : " << area()      << "\n"
           << "  Периметр : " << perimeter() << "\n";
    }
};

int main() {
    const int N = 4;
    Quadrilateral* shapes[N] = {
        new Square(5),
        new Rectangle(8, 3),
        new Parallelogram(10, 6, 60),
        new Trapezoid(4, 10, 5, 5, 4)
    };

    for (int i = 0; i < N; ++i)
        cout << *shapes[i] << "\n";

    int maxS = 0, minP = 0;
    for (int i = 1; i < N; ++i) {
        if (shapes[i]->area()      > shapes[maxS]->area())      maxS = i;
        if (shapes[i]->perimeter() < shapes[minP]->perimeter()) minP = i;
    }

    cout << "Найбільша площа   : " << shapes[maxS]->name() << " = " << shapes[maxS]->area()      << "\n";
    cout << "Найменший периметр: " << shapes[minP]->name() << " = " << shapes[minP]->perimeter() << "\n";

    for (int i = 0; i < N; ++i)
        delete shapes[i];

    return 0;
}
